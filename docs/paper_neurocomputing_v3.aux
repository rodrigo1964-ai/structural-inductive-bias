\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Experiment~1: Test MSE vs.\ training sample size $N$ for the damped oscillator ($\beta = 1$). The implicit model (dashed) achieves approximately $3\times $ lower test error than the explicit model (solid) for $N \ge 200$. Bands show $\pm 1$ std over 20 seeds (log scale).}}{8}{figure.1}\protected@file@percent }
\newlabel{fig:exp1}{{1}{8}{Experiment~1: Test MSE vs.\ training sample size $N$ for the damped oscillator ($\beta = 1$). The implicit model (dashed) achieves approximately $3\times $ lower test error than the explicit model (solid) for $N \ge 200$. Bands show $\pm 1$ std over 20 seeds (log scale)}{figure.1}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {10.2}Experiment 2: Nonlinearity absorption ($\beta > 1$)}{8}{subsection.10.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {10.3}Experiment 3: HAM residual learning}{9}{subsection.10.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {10.4}Experiment 4: Counterexample ($\mathcal  {S} = 1$)}{9}{subsection.10.4}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {10.5}Experiment 5: Closed-form analytical verification}{9}{subsection.10.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Experiment~3: Test MSE vs.\ HAM truncation order $K$ for the nonlinear pendulum ($N = 100$). The explicit model (horizontal band) does not benefit from $K$. The implicit model (dashed) achieves exponential decay of MSE with $K$, reaching $7\times $ improvement at $K = 5$. Estimated $\rho \approx 0.45$.}}{10}{figure.2}\protected@file@percent }
\newlabel{fig:exp3}{{2}{10}{Experiment~3: Test MSE vs.\ HAM truncation order $K$ for the nonlinear pendulum ($N = 100$). The explicit model (horizontal band) does not benefit from $K$. The implicit model (dashed) achieves exponential decay of MSE with $K$, reaching $7\times $ improvement at $K = 5$. Estimated $\rho \approx 0.45$}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {10.6}Summary of experimental results}{10}{subsection.10.6}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {1}{\ignorespaces Summary of experimental results. The structural content $\mathcal  {S}(F)$ is estimated from the empirical MSE ratio at the largest sample size. The advantage column reports the MSE ratio $\mathrm  {MSE}_{\mathrm  {exp}}/\mathrm  {MSE}_{\mathrm  {imp}}$ at the most favorable operating point.}}{10}{table.1}\protected@file@percent }
\newlabel{tab:summary}{{1}{10}{Summary of experimental results. The structural content $\mathcal {S}(F)$ is estimated from the empirical MSE ratio at the largest sample size. The advantage column reports the MSE ratio $\mathrm {MSE}_{\mathrm {exp}}/\mathrm {MSE}_{\mathrm {imp}}$ at the most favorable operating point}{table.1}{}}
